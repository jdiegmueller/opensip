# SIP account / registrar
SIP_SERVER=sip.example.com
SIP_PORT=5060
SIP_DOMAIN=sip.example.com
SIP_USERNAME=alice
SIP_PASSWORD=changeme

# Local listen port for SIP
LOCAL_SIP_PORT=5060

# Full SIP URI or bare number; bare numbers are wrapped with SIP_SERVER
CALL_TARGET=sip:bob@sip.example.com

# Runtime knobs
CALL_DURATION_S=30
STATS_LOG_INTERVAL_S=5
LOG_LEVEL=INFO
